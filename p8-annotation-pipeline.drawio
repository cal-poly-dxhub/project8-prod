        <mxCell id="JfS3C-AzQht7yLgw44mh-48" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacing=8;fillColor=#ffffff;strokeColor=#E0E0E0;rounded=1;" value="&lt;b&gt;Data Flow&lt;/b&gt;&lt;br&gt;&lt;br&gt;1. User authenticates via Cognito&lt;br&gt;2. Uploads .docx via presigned URL to S3&lt;br&gt;3. S3 event triggers SQS message&lt;br&gt;4. ECS Worker polls SQS, downloads file&lt;br&gt;5. Worker calls Bedrock (Claude Sonnet 4.6)&lt;br&gt;6. Annotations saved to Results Bucket&lt;br&gt;7. Job status updated in DynamoDB&lt;br&gt;8. User downloads results via presigned URL" vertex="1">
          <mxGeometry height="230" width="300" x="2150" y="200" as="geometry" />
        </mxCell>
        <mxCell id="JfS3C-AzQht7yLgw44mh-49" parent="1" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;spacing=6;fillColor=#ffffff;strokeColor=#E0E0E0;rounded=1;" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;&lt;hr&gt;Solid line: Primary data flow&lt;br&gt;Dashed line: Async / monitoring&lt;br&gt;Red dashed: Error path" vertex="1">
          <mxGeometry height="100" width="200" x="2150" y="460" as="geometry" />
        </mxCell>
